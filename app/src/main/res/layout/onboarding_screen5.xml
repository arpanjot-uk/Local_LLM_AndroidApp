<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="4dp"
    android:layout_margin="8dp">

    <pl.droidsonroids.gif.GifImageView
        android:id="@+id/imageView"
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:src="@drawable/ic_animation_relaxing"
        android:contentDescription="Patience animation" />


    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Sometimes, Even I Need a Moment"
        android:textSize="22sp"
        android:fontFamily="@font/karla_semi_bold"
        android:gravity="center"
        android:paddingTop="0dp"
        android:textColor="@color/text"
        android:contentDescription="Tag line"/>
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="I’m like that friend you absolutely adore—even when they take their sweet time to reply! ❤️🤖"
        android:textSize="16sp"
        android:gravity="center"
        android:fontFamily="@font/karla_regular"
        android:paddingTop="4dp"
        android:textColor="@color/text"
        android:contentDescription="Explaning model processing time"/>



    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🕒 Sometimes, I might need a bit longer to respond, especially when handling big tasks like processing files or images.
        \n\n📂 If I don’t reply at all, it could be because your device’s memory is running low.
        \n\nBut don’t worry! With a little patience and some extra space on your device, I’ll always do my best to help you out. 🚀✨"
        android:textSize="16sp"
        android:gravity="center"
        android:fontFamily="@font/karla_regular"
        android:paddingTop="24dp"
        android:textColor="@color/text"/>
</LinearLayout>