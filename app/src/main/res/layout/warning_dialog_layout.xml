<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_gravity="center"
    android:layout_margin="20dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="8dp"
    android:background="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/warning_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Insufficient Memory"
            android:textAppearance="?android:attr/textAppearanceLarge"
            android:textStyle="bold"
            android:textColor="@color/text"
            android:layout_marginBottom="10dp"
            android:gravity="center_horizontal"
            android:contentDescription="Warning title"/>

        <TextView
            android:id="@+id/warning_message"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="This application requires at least 6 GB of RAM to run properly. Your device does not meet this requirement."
            android:textColor="@color/text"
            android:textSize="16sp"
            android:gravity="center_horizontal"
            android:contentDescription="Warning app not compatible"/>

        <ImageButton
            android:id="@+id/applySettingsButton"
            android:layout_width="80dp"
            android:layout_height="50dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="20dp"
            android:background="@drawable/main_rounded_button"
            android:src="@drawable/ic_exit"
            android:hapticFeedbackEnabled="true"
            android:visibility="visible"
            android:contentDescription="Exit app"/>
    </LinearLayout>

</androidx.cardview.widget.CardView>
