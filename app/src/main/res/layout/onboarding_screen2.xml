<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="4dp"
    android:layout_margin="8dp">

    <pl.droidsonroids.gif.GifImageView
        android:id="@+id/imageView"
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:src="@drawable/ic_animation_judgment"
        android:contentDescription="Judging Animation" />


    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Let’s Find the Right Agent for You!"
        android:textSize="22sp"
        android:fontFamily="@font/karla_semi_bold"
        android:gravity="center"
        android:paddingTop="16dp"
        android:textColor="@color/text"
        android:contentDescription="Message chose best agent for HumNod Lite LLM" />

</LinearLayout>