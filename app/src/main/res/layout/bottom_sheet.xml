<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:tools="http://schemas.android.com/tools"
    android:padding="16dp"
    android:background="@color/white">

    <!-- Close Button (top right corner) -->
    <ImageButton
        android:id="@+id/close_button"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_alignParentEnd="true"
        android:layout_alignParentTop="true"
        android:layout_margin="16dp"
        android:elevation="8dp"
        android:background="@drawable/main_rounded_button"
        android:hapticFeedbackEnabled="true"
        android:src="@drawable/ic_close"
        tools:ignore="UseAppTint"
        android:contentDescription="Close settings"/>

    <!-- Settings Page Title -->
    <TextView
        android:id="@+id/settingsPageTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentStart="true"
        android:layout_alignParentTop="true"
        android:layout_marginStart="72dp"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="16dp"
        android:gravity="center"
        android:elevation="8dp"
        android:fontFamily="@font/karla_semi_bold"
        android:layout_toStartOf="@id/close_button"
        android:text="Settings"
        android:textColor="@color/text"
        android:textSize="30sp"
        android:textStyle="bold"
        android:contentDescription="Page title"/>

    <!-- Container for Max Response Length -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/maxResponseLengthContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/close_button"
        android:layout_marginTop="16dp"
        android:padding="16dp"
        android:elevation="8dp"
        android:layout_marginHorizontal="10dp"
        android:background="@drawable/hollow_background_4dp">

        <!-- Max Response Length Label -->
        <TextView
            android:id="@+id/tvMaxLength"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Max Response Length"
            android:textSize="16sp"
            android:textColor="@color/text"
            android:fontFamily="@font/karla_regular"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/idEdtMaxLength"
            app:layout_constraintBottom_toBottomOf="@+id/idEdtMaxLength"
            app:layout_constraintHorizontal_chainStyle="packed"
            android:contentDescription="LLM max response lenght text"/>

        <!-- Max Response Length EditText -->
        <EditText
            android:id="@+id/idEdtMaxLength"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:inputType="number"
            android:hint="2000"
            android:text="2000"
            android:background="@drawable/hollow_background_2dp"
            android:padding="12dp"
            android:gravity="center"
            android:textColor="@color/text"
            android:fontFamily="@font/karla_regular"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@+id/tvMaxLength"
            app:layout_constraintWidth_percent="0.5"
            android:contentDescription="LLM max response lenght input"/>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Container for Length Penalty -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/lengthPenaltyContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/maxResponseLengthContainer"
        android:layout_marginTop="16dp"
        android:padding="16dp"
        android:elevation="8dp"
        android:layout_marginHorizontal="10dp"
        android:background="@drawable/hollow_background_4dp">

        <!-- Length Penalty Label -->
        <TextView
            android:id="@+id/tvLengthPenalty"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Length Penalty"
            android:textSize="16sp"
            android:textColor="@color/text"
            android:fontFamily="@font/karla_regular"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/idEdtLengthPenalty"
            app:layout_constraintBottom_toBottomOf="@+id/idEdtLengthPenalty"
            app:layout_constraintHorizontal_chainStyle="packed"
            android:contentDescription="LLM max response penalty text"/>

        <!-- Length Penalty EditText -->
        <EditText
            android:id="@+id/idEdtLengthPenalty"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:inputType="number|numberDecimal"
            android:hint="1.0"
            android:text="1.0"
            android:background="@drawable/hollow_background_2dp"
            android:padding="12dp"
            android:gravity="center"
            android:textColor="@color/text"
            android:fontFamily="@font/karla_regular"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@+id/tvLengthPenalty"
            app:layout_constraintWidth_percent="0.5"
            android:contentDescription="LLM max response penalty input"/>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Container for Agent Type -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/agentTypeContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/lengthPenaltyContainer"
        android:layout_marginTop="16dp"
        android:padding="16dp"
        android:elevation="8dp"
        android:layout_marginHorizontal="10dp"
        android:background="@drawable/hollow_background_4dp">

        <!-- Agent Type Label -->
        <TextView
            android:id="@+id/tvAgentType"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Agent Type"
            android:textSize="16sp"
            android:textColor="@color/text"
            android:fontFamily="@font/karla_regular"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/idSpinnerResponseMode"
            app:layout_constraintBottom_toBottomOf="@+id/idSpinnerResponseMode"
            app:layout_constraintHorizontal_chainStyle="packed"
            android:contentDescription="LLM agent type text"/>

        <!-- Agent Type Spinner -->
        <Spinner
            android:id="@+id/idSpinnerResponseMode"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:padding="8dp"
            android:background="@drawable/hollow_background_2dp"
            android:popupBackground="@drawable/hollow_background_2dp"
            android:dropDownVerticalOffset="50dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@+id/tvAgentType"
            android:textColor="@color/text"
            android:fontFamily="@font/karla_regular"
            app:layout_constraintWidth_percent="0.5"
            android:contentDescription="LLM agent type input"/>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Attach Button -->
    <ImageButton
        android:id="@+id/applySettingsButton"
        android:layout_width="80dp"
        android:layout_height="50dp"
        android:layout_centerHorizontal="true"
        android:layout_below="@id/agentTypeContainer"
        android:layout_marginTop="16dp"
        android:background="@drawable/main_rounded_button"
        android:src="@drawable/ic_apply"
        android:hapticFeedbackEnabled="true"
        android:elevation="8dp"
        android:visibility="visible"
        android:contentDescription="Apply LLM data processing settings"/>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/emptyContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/applySettingsButton"
        android:layout_marginTop="20dp"
        android:padding="2dp"
        android:background="@drawable/hollow_background_2dp">
    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/helpContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/emptyContainer"
        android:layout_marginTop="20dp"
        android:padding="16dp"
        android:elevation="8dp"
        android:layout_marginHorizontal="10dp"
        android:layout_marginBottom="20dp"
        android:background="@drawable/hollow_background_4dp">

        <!-- Help Text -->
        <TextView
            android:id="@+id/helpText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Need more information about these settings?"
            android:textSize="16sp"
            android:textColor="@color/text"
            android:layout_marginRight="16dp"
            android:fontFamily="@font/karla_regular"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/helpButton"
            app:layout_constraintHorizontal_chainStyle="packed"
            android:contentDescription="Help page text"/>

        <!-- Help Button -->
        <ImageButton
            android:id="@+id/helpButton"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="16dp"
            android:background="@drawable/main_rounded_button"
            android:src="@drawable/ic_help"
            android:hapticFeedbackEnabled="true"
            app:tint="@color/white"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:contentDescription="Help page on HumNod"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</RelativeLayout>
