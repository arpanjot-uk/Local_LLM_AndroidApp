<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="4dp"
    android:layout_margin="8dp">

    <pl.droidsonroids.gif.GifImageView
        android:id="@+id/imageView"
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:src="@drawable/ic_animation_celebration"
        android:contentDescription="Thank you animation" />


    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Thank you for choosing me!"
        android:textSize="22sp"
        android:fontFamily="@font/karla_semi_bold"
        android:gravity="center"
        android:paddingTop="16dp"
        android:textColor="@color/text"
        android:contentDescription="Thank you message"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Ready to explore? Let's go!"
        android:textSize="18sp"
        android:fontFamily="@font/karla_regular"
        android:gravity="center"
        android:paddingTop="8dp"
        android:textColor="@color/text"
        android:contentDescription="Tag line"/>
</LinearLayout>